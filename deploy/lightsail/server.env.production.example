NODE_ENV=production
PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/pinkpaisa
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace-with-a-long-random-secret

ADMIN_BOOTSTRAP_EMAIL=pinkpaisawellness2018@gmail.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-one-time-strong-bootstrap-password
ALLOW_BOOTSTRAP_SEEDING=false

SERVER_URL=https://www.pinkpaisa.in
PUBLIC_MEDIA_BASE_URL=https://www.pinkpaisa.in
FRONTEND_URL=https://www.pinkpaisa.in
PUBLIC_APP_URL=https://www.pinkpaisa.in
CLIENT_URL=https://www.pinkpaisa.in
CORS_EXTRA_ORIGINS=

EMAIL_PROVIDER=smtp
EMAIL_FROM="Pink Paisa <pinkpaisawellness2018@gmail.com>"
EMAIL_REPLY_TO=pinkpaisawellness2018@gmail.com
SUPPORT_EMAIL=pinkpaisawellness2018@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=pinkpaisawellness2018@gmail.com
SMTP_PASSWORD=replace_with_google_app_password
SMTP_REJECT_UNAUTHORIZED=true

STANDARD_SHIPPING_COST=79
FREE_SHIPPING_THRESHOLD=999

AMAZON_ASSOCIATE_TAG_IN=replace-with-amazon-in-associate-tag
AMAZON_ASSOCIATE_TAG_US=replace-with-amazon-us-associate-tag

INSTAGRAM_APP_ID=replace-with-instagram-app-id
INSTAGRAM_APP_SECRET=replace-with-instagram-app-secret
INSTAGRAM_REDIRECT_URI=https://www.pinkpaisa.in/api/instagram/admin/connect/callback
INSTAGRAM_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key
INSTAGRAM_GRAPH_API_VERSION=v23.0

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_COMPRESSION=86

GEMINI_API_KEY=replace-with-google-gemini-api-key
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_ASPECT_RATIO=4:5
GEMINI_IMAGE_SIZE=2K

OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_IMAGE_MODEL=
OPENROUTER_SITE_URL=https://www.pinkpaisa.in
OPENROUTER_APP_NAME=Pink Paisa

PHONEPE_CLIENT_ID=replace-if-using-phonepe
PHONEPE_CLIENT_SECRET=replace-if-using-phonepe
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=PRODUCTION
PHONEPE_CALLBACK_USERNAME=replace-if-using-phonepe-callbacks
PHONEPE_CALLBACK_PASSWORD=replace-if-using-phonepe-callbacks

MARKETING_DAILY_BATCH_ENABLED=true
MARKETING_AI_FALLBACK_TO_TEMPLATE=false
MARKETING_AGENT_POLL_MS=5000
MARKETING_SCHEDULER_POLL_MS=30000
MARKETING_STALE_TASK_MS=1800000
MARKETING_MIN_SCHEDULE_DELAY_MS=300000
AFFILIATE_LINK_CHECK_DAILY_ENABLED=true
AFFILIATE_LINK_CHECK_HOUR_IST=03
AFFILIATE_LINK_CHECK_MINUTE_IST=10
AFFILIATE_LINK_CHECK_DAILY_LIMIT=50

BACKUP_DIR=/home/ubuntu/pinkpaisa-backups
BACKUP_RETENTION_DAYS=14
BACKUP_SCRIPT_PATH=/home/ubuntu/pinkpaisa/deploy/lightsail/scripts/backup-all.sh

LOG_LEVEL=info
